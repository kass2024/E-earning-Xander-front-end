# Production build (npm run build) — cPanel API with public/index.php
# VITE_API_URL=https://api.parrotglobalstudyacademy.ca/public/index.php/api/admin

# Local dev (npm run dev) — Laravel on :8000, Vite proxies /api
VITE_API_URL=http://localhost:8000/api/admin
VITE_DEV_API_PROXY=http://127.0.0.1:8000

# Google Maps embed (optional — footer map; enable Maps Embed API on the key)
VITE_GOOGLE_MAPS_EMBED_KEY=

# Application
# VITE_APP_NAME=Xander Learning Hub
VITE_APP_VERSION=1.0.0

# pCloud (optional — course materials)
VITE_PCLOUD_ACCESS_TOKEN=
VITE_PCLOUD_BASE_URL=https://api.pcloud.com
